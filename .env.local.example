# ============================================================
# PROspector – Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local sur GitHub
# ============================================================

# --- Supabase (Dashboard > Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici

# Clé service (backend uniquement – jamais exposée côté client)
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En production : https://prospector.vercel.app (ou votre domaine)

# --- Cron (secret partagé entre vercel.json et les routes sync-all/ingest) ---
CRON_SECRET=changez_ce_secret_en_production

# --- Auth Microsoft (Supabase Dashboard > Auth > Providers > Azure)
# Ces valeurs sont configurées dans Supabase, pas directement ici.
# Voir README_PHASE0.md pour la procédure complète.
